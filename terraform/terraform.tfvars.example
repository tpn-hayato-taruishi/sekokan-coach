aws_region  = "ap-northeast-1"
environment = "dev"
app_name    = "e-platch"

app_runner_cpu    = "256"
app_runner_memory = "512"

bedrock_model_id          = "apac.anthropic.claude-3-haiku-20240307-v1:0"
bedrock_monthly_limit_yen = 5000

budget_limit_yen     = 4500
budget_usd_jpy_rate  = 150
ecr_force_delete     = true

admin_token = "CHANGE_ME_TO_A_LONG_RANDOM_VALUE"

# Optional. SNS will send a confirmation email before notifications start.
# alert_email = "your-email@example.com"

# Optional. Add JST holiday dates when App Runner should not resume.
# holidays = ["2026-07-20", "2026-08-11"]
